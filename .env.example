# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Chain / RPC ───────────────────────────────────────────────────────────────
# Moonbeam (Polkadot EVM) — replace with actual RPC for production
NEXT_PUBLIC_CHAIN_ID=1284
NEXT_PUBLIC_RPC_URL=https://rpc.api.moonbeam.network

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# Required by RainbowKit — get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Contracts ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_PRISMA_ROUTER=
NEXT_PUBLIC_CONTRACT_TUSD=
NEXT_PUBLIC_CONTRACT_TEUR=
NEXT_PUBLIC_CONTRACT_TJPY=
NEXT_PUBLIC_CONTRACT_TGBP=
NEXT_PUBLIC_CONTRACT_USDC=

# ─── Foundry Deployment ───────────────────────────────────────────────────────
# Private key for contract deployment (DO NOT commit actual keys!)
PRIVATE_KEY=
# Moonbase Alpha testnet RPC
MOONBASE_RPC_URL=https://rpc.api.moonbase.moonbeam.network
# Optional: Moonscan API key for contract verification
MOONSCAN_API_KEY=

# ─── External Data ─────────────────────────────────────────────────────────────
# Pyth price feed endpoint for on-chain oracle price data
NEXT_PUBLIC_PYTH_ENDPOINT=https://hermes.pyth.network
# Pyth Oracle contract address on Moonbase Alpha
NEXT_PUBLIC_PYTH_CONTRACT=0xA2aa501b19aff244D90cc15a4Cf739D2725B5729
